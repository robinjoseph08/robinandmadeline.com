# Keep the Docker build context lean: the image build regenerates the tygo
# types and rebuilds both the bundle and the binaries from source, so local
# artifacts and tooling state never belong in the context.
.git
node_modules
build
tmp
dist
coverage
playwright-report
test-results
blob-report
app/types/generated
e2e
docs
.github
.idea
.vscode
.playwright-mcp
*.log
.DS_Store
Dockerfile
.dockerignore
fly.toml
docker-compose.yml
README.md
CLAUDE.md
CONTEXT.md
.wktr.yaml
.wktr.local.yaml
.air.toml
