# Environment configuration for the robinandmadeline.com API server.
# Copy to .env and adjust as needed. All values have local-dev defaults baked
# into pkg/config, so the server runs out of the box against docker-compose.

# Postgres connection string. Matches the docker-compose Postgres service.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/robinandmadeline?sslmode=disable

# Port the HTTP API server listens on.
PORT=3690

# Admin credentials for the admin dashboard.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Secret used to sign JWT auth tokens. CHANGE THIS IN PRODUCTION.
JWT_SECRET=dev-secret-change-me-in-production
